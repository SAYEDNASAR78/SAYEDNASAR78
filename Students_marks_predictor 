      "source": [
        "\n",
        "import pandas as pd\n",
        "\n",
        "# Step 1: Khud ka data bana rahe hain\n",
        "data = {\n",
        "    'Name': ['Ali', 'Sara', 'Bilal', 'Ayesha', 'Zain'],\n",
        "    'Study_Hours': [5, 8, 3, 10, 2],\n",
        "    'Attendance': [90, 95, 70, 100, 60]\n",
        "}\n",
        "\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "# Step 2: Marks predict karne ka formula\n",
        "df['Predicted_Marks'] = df['Study_Hours'] * 7 + df['Attendance'] * 0.3\n",
        "\n",
        "# Step 3: Pass/Fail ka risk\n",
        "df['Result'] = df['Predicted_Marks'].apply(lambda x: 'Pass' if x >= 50 else 'Fail')\n",
        "\n",
        "print(df)\n",
        "\n",
        "from sklearn.linear_model import LinearRegression\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "# Step 1: Data ko X aur Y me toro\n",
        "X = df[['Study_Hours', 'Attendance']]  # Input: ghante + hazri\n",
        "y = df['Predicted_Marks']              # Output: marks\n",
        "\n",
        "# Step 2: Data ko 80% training, 20% test me baanto\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)\n",
        "\n",
        "# Step 3: Machine ko training do\n",
        "model = LinearRegression()\n",
        "model.fit(X_train, y_train)\n",
        "\n",
        "# Step 4: Prediction karo\n",
        "pred_marks = model.predict(X_test)\n",
        "print(\"Machine ke hisaab se marks:\", pred_marks)\n",
        "\n",
        "# Step 5: Classification - Pass/Fail\n",
        "pred_result = ['Pass' if m >= 50 else 'Fail' for m in pred_marks]\n",
        "print(\"Result:\", pred_result)"
