        "\n",
        "import pandas as pd\n",
        "\n",
        "# Diabetes ka mini data banaya - tumhare thesis wala\n",
        "data = {\n",
        "    'Patient': ['Ayesha', 'Bilal', 'Sara', 'Ahmed', 'Zainab', 'Usman'],\n",
        "    'Glucose': [148, 85, 183, 89, 137,95],\n",
        "    'BMI': [33.6, 26.6, 23.3, 28.1, 43.1,24.00],\n",
        "    'Age': [50, 31, 32, 21, 33, 28]\n",
        "}\n",
        "\n",
        "df = pd.DataFrame(data)\n",
        "print(\"Original Data:\")\n",
        "print(df)\n",
        "\n",
        "# Risk score banate hain - Predictor wala kaam\n",
        "df['Risk_Score'] = (df['Glucose']/200 + df['BMI']/50) * 100\n",
        "df['Risk_Level'] = df['Risk_Score'].apply(lambda x: 'High' if x > 100 else 'Normal')\n",
        "\n",
        "print(\"\\nRisk Prediction:\")\n",
        "print(df[['Patient', 'Risk_Score', 'Risk_Level']])"
      ]
